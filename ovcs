#!ruby

require "optparse"
require "open3"

COMMANDS = [
  "build",
  "burn",
  "upload"
]

APPLICATIONS = {
  "vms"                  => "vms",
  "infotainment"         => "infotainment",
  "radio-control-bridge" => "bridges/radio_control_bridge",
  "ros-bridge"           => "bridges/ros_bridge"
}

# Vehicles are discovered at runtime from vehicles/<name>/ — the CLI stays
# out of the business of enumerating them. The directory name (snake_case)
# maps to the top-level Elixir module name (UpperCamelCase) via
# `Macro.underscore` in reverse, e.g. ovcs1 → Ovcs1, ovcs_mini → OvcsMini.
def discover_vehicles(root)
  Dir.glob("#{root}/vehicles/*/mix.exs").map { |p| File.basename(File.dirname(p)) }.sort
end

def vehicle_module(vehicle_dir)
  vehicle_dir.split("_").map(&:capitalize).join
end

def mix_target(root, vehicle_dir, application)
  side = application == "vms" ? ":vms" : ":infotainment"
  module_name = vehicle_module(vehicle_dir)
  snippet = "IO.write(#{module_name}.nerves_target(#{side}))"
  output, status = Open3.capture2(
    { "MIX_ENV" => "dev" },
    "mix", "run", "--no-start", "--no-deps-check", "-e", snippet,
    chdir: "#{root}/vehicles/#{vehicle_dir}"
  )
  status.success? ? output.strip : nil
end

options = {}

def stop(parser, message)
  puts "!! #{message}"
  puts
  puts parser.help
  exit(-1)
end

def compute_host(vehicle, application)
  "#{vehicle.gsub("_", "-")}-#{application}.local"
end

vehicles = discover_vehicles(__dir__)

parser = OptionParser.new do |parser|
  parser.banner = "Usage: ./ovcs --command [COMMAND] --vehicle [VEHICLE] --application [APP] (--host [HOST] --file [FILE])"
  parser.on("-c", "--command [COMMAND]", String, "Command to perform: #{COMMANDS.join(" | ")}") do |command|
    stop(parser, "Invalid --command #{command}") unless COMMANDS.include?(command)
    command
  end

  parser.on("-v", "--vehicle [VEHICLE]", String, "Target vehicle: #{vehicles.join(" | ")}") do |vehicle|
    stop(parser, "Invalid --vehicle #{vehicle}") unless vehicles.include?(vehicle)
    vehicle
  end

  parser.on("-a", "--application [APP]", String, "App to run: #{APPLICATIONS.keys.join(" | ")}") do |application|
    stop(parser, "Invalid --application #{application}") unless APPLICATIONS.keys.include?(application)
    application
  end

  parser.on("-h", "--host [HOST]", String, "Optional: Target host, e.g.  nerves.local") do |host|
    stop(parser, "Invalid --host #{host}") if !host.nil? && host.strip == ""
    host
  end

  parser.on("-f", "--file [FILE]", String, "Optional: custom firmware file to push to target host, e.g.  custom.fw") do |file|
    stop(parser, "Invalid --file #{file}") if file.nil? && file.strip == ""
    file
  end
end

parser.parse!(into: options)

stop(parser, "Missing --command") if options[:command].nil?
stop(parser, "Missing --vehicle") if options[:vehicle].nil?
stop(parser, "Missing --application") if options[:application].nil?

firmware_directory = "#{__dir__}/#{APPLICATIONS[options[:application]]}/firmware"
script             = "./#{options[:command]}.sh"

if options[:command] == "upload"
  host = options[:host] || compute_host(options[:vehicle], options[:application])
  script += " #{host}"
  if !options[:file].nil?
    script += " #{options[:file]}"
  end
end

env = "VEHICLE=#{vehicle_module(options[:vehicle])}"
target = mix_target(__dir__, options[:vehicle], options[:application])
env += " MIX_TARGET=#{target}" if target

Open3.pipeline("#{env} #{script}", chdir: firmware_directory)

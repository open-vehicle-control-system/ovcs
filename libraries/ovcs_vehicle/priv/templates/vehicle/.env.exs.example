# One `{ssid, psk}` tuple per Wi-Fi network the firmware should know
# about (wpa_supplicant picks whichever is in range). Use `[]` to skip
# wlan0 entirely. Parsed at config time with `Code.eval_string/1`, so
# the value must be a valid Elixir list literal.
System.put_env("WIFI_NETWORKS", ~s([
  {"MyHomeWiFi", "homepassword"},
  {"MyOfficeWiFi", "officepassword"}
]))
System.put_env("AUTHORIZED_SSH_KEYS", Enum.join([
  "key1",
  "key2"
], ","))
System.put_env("SECRET_KEY_BASE", "random_string")
System.put_env("SIGNING_SALT", "random_string")
# Zenoh router that ros_bridge connects to (tcp/<ip>:7447). Falls
# back to 127.0.0.1 in the vehicle module when unset. Only needed
# for vehicles that bundle ros_bridge.
System.put_env("ZENOH_ENDPOINT_IP", "192.168.10.95")

# Copy to `.env` and adjust. `docker compose` picks `.env` up
# automatically.
#
# With the bundled zenohd service running on the same host, the ros2
# container connects to it via 127.0.0.1. Change this only if you
# point the ros2 container at a Zenoh router on a different machine.
ZENOH_ENDPOINT_IP=127.0.0.1

# Foxglove Studio connects to ws://<host-ip>:$FOXGLOVE_BRIDGE_PORT
FOXGLOVE_BRIDGE_PORT=8765
